#!/usr/bin/env bash
# atelier-opencode — launch opencode, then print an Atelier session summary.

set -euo pipefail

TASK=""
DOMAIN=""
SHOW_SUMMARY=1
ROOT="${ATELIER_ROOT:-${ATELIER_STORE_ROOT:-}}"
ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --task)
            if [[ $# -lt 2 ]]; then
                echo "atelier-opencode: missing value for --task" >&2
                exit 64
            fi
            TASK="$2"
            shift 2
            ;;
        --domain)
            if [[ $# -lt 2 ]]; then
                echo "atelier-opencode: missing value for --domain" >&2
                exit 64
            fi
            DOMAIN="$2"
            shift 2
            ;;
        --root|--atelier-root)
            if [[ $# -lt 2 ]]; then
                echo "atelier-opencode: missing value for $1" >&2
                exit 64
            fi
            ROOT="$2"
            shift 2
            ;;
        --no-session-summary)
            SHOW_SUMMARY=0
            shift
            ;;
        --)
            shift
            while [[ $# -gt 0 ]]; do
                ARGS+=("$1")
                shift
            done
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

if ! command -v opencode >/dev/null 2>&1; then
    echo "atelier-opencode: 'opencode' not found on PATH" >&2
    exit 127
fi

WORKSPACE_ROOT="${ATELIER_WORKSPACE_ROOT:-$(pwd)}"
if [[ -z "$ROOT" ]]; then
    if [[ -d "${WORKSPACE_ROOT}/.atelier" ]]; then
        ROOT="${WORKSPACE_ROOT}/.atelier"
    else
        ROOT="${HOME}/.atelier"
    fi
fi

if [[ -n "$TASK" ]]; then
    echo "[atelier:opencode] task: $TASK"
    if [[ -n "$DOMAIN" ]]; then
        echo "[atelier:opencode] domain: $DOMAIN"
    fi
fi

set +e
ATELIER_WORKSPACE_ROOT="$WORKSPACE_ROOT" opencode "${ARGS[@]}"
STATUS=$?
set -e

if [[ "$SHOW_SUMMARY" == "1" ]]; then
    echo
    echo "[atelier:opencode] session summary"
    ATELIER_ROOT="$ROOT" atelier session report --no-color 2>/dev/null || true
fi

exit "$STATUS"
